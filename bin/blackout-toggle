#!/usr/bin/env bash
# Toggle the blackout overlay. All state lives in the daemon: SIGUSR1 flips
# it on/off. No brightness handling — on OLED the black pixels are the blackout.
PID_FILE="/run/user/$UID/blackout-overlay.pid"

if [[ ! -f "$PID_FILE" ]] || ! pid=$(<"$PID_FILE") || ! kill -0 "$pid" 2>/dev/null; then
    echo "blackout daemon not running; start with: systemctl --user start blackout-overlay" >&2
    exit 1
fi

kill -USR1 "$pid"
